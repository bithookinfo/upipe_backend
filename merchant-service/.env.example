#
# Merchant Service – .env.example
# Copy this file to `.env` and fill in real values.
#

# Service
PORT=3102

# Database
# Example (local MySQL):
#   mysql://user:pass@localhost:3306/greenpay_merchant
DATABASE_URL="mysql://user:pass@localhost:3306/greenpay_merchant"

# Service URLs (internal)
IDENTITY_SERVICE_URL="http://localhost:3105"
ORGANIZATION_SERVICE_URL="http://localhost:3106"
PAYMENT_SERVICE_URL="http://localhost:3103"
SUBSCRIPTION_SERVICE_URL="http://localhost:3104"
MERCHANT_SERVICE_URL="http://localhost:3102"

# Auth
# Must match identity-service JWT_SECRET
JWT_SECRET="change-me-jwt-secret"

# PhonePe / payment provider integration
# Your checksum endpoint (if using PhonePe simple flow)
PHONEPE_CHECKSUM_ENDPOINT="https://your-domain.com/phonepe/checksum.php?trd="

# Redis (for caching / jobs)
REDIS_HOST="localhost"
REDIS_PORT=6379

# If true, uses web flow for PhonePe
PHONEPE_USE_WEB_FLOW=true

# Web OTP / hCaptcha (required when web flow needs captcha solving)
# CAPTCHA_API_KEY=

# Persistent Chromium profile for PhonePe web-api (trust cookies; survives across syncs).
# Default: <cwd>/.phonepe-profiles — in Docker/K8s set to a mounted volume or profiles reset every deploy.
# PHONEPE_PERSISTENT_PROFILE_ROOT=/var/lib/phonepe-profiles
PHONEPE_PERSISTENT_BROWSER=true

# After persistent browser fails, run ephemeral Chromium before axios (recommended true).
# PHONEPE_WEB_EPHEMERAL_BEFORE_AXIOS=true

# Experimental: axios call to transactions/recent before list (can add latency / drift). Default off.
# PHONEPE_WEB_AXIOS_RECENT_PREFLIGHT=false

# Only if preflight is on and you mirror Burp analytics — all required for fire-and-forget bulk/ingest.
# PHONEPE_WEB_BULK_INGEST_AFTER_RECENT=false
# PHONEPE_WEB_ANALYTICS_USER_ID=
# PHONEPE_WEB_ANALYTICS_MERCHANT_USER_ID=

# Rare: legacy warmer path in phonepe-simple (default false)
# PHONEPE_ENABLE_LEGACY_WARMER=false

# Redis auth (only if your Redis requires a password)
# REDIS_PASSWORD=

# Optional cache TTL for gateway availability (ms)
# GATEWAY_AVAILABLE_CACHE_TTL_MS=

# CORS – comma-separated list of allowed origins (frontends)
ALLOWED_ORIGINS=https://upipe.tech,https://app.upipe.tech,https://admin.upipe.tech,http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4000


FRONTEND_URL=https://app.upipe.tech
