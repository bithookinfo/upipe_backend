# Service
PORT=3100

# Internal service URLs (HTTP)
IDENTITY_SERVICE_URL="http://localhost:3105"
MERCHANT_SERVICE_URL="http://localhost:3102"
PAYMENT_SERVICE_URL="http://localhost:3103"
SUBSCRIPTION_SERVICE_URL="http://localhost:3104"
ORGANIZATION_SERVICE_URL="http://localhost:3106"
NOTIFICATION_SERVICE_URL="http://localhost:3006"

# CORS – comma-separated list of allowed origins (frontends)
ALLOWED_ORIGINS=https://upipe.tech,https://app.upipe.tech,https://admin.upipe.tech,http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4000


FRONTEND_URL=https://app.upipe.tech
