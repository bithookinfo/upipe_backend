{
  "name": "@greenpay/api-gateway",
  "version": "1.0.5",
  "description": "Payment processing and transaction service for Upipe",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
