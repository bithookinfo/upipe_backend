#
# Subscription Service – .env.example
# Copy this file to `.env` and fill in real values.
#

# Service
PORT=3104

# Database
# Example (local MySQL):
#   mysql://user:pass@localhost:3306/greenpay_subscription
DATABASE_URL="mysql://user:pass@localhost:3306/greenpay_subscription"

# Internal service URLs
ORGANIZATION_SERVICE_URL="http://localhost:3106"

# Auth
# Must match identity-service JWT_SECRET
JWT_SECRET="change-me-jwt-secret"

# CORS – comma-separated list of allowed origins (frontends)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

