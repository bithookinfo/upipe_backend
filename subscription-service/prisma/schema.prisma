generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SubscriptionPlan {
  id          String @id @default(uuid()) @db.VarChar(36)
  name        String @db.VarChar(100)
  code        String @unique @db.VarChar(50)
  description String? @db.Text
  
  price        Decimal      @db.Decimal(10, 2)
  currency     String       @default("INR") @db.VarChar(3)
  billingCycle BillingCycle @default(MONTHLY) @map("billing_cycle")
  trialDays    Int          @default(0) @map("trial_days")
  durationDays Int?         @map("duration_days") // Custom duration in days
  
  maxUsers       Int @default(5) @map("max_users")
  maxMerchants   Int @default(3) @map("max_merchants")
  maxTransactions Int @default(1000) @map("max_transactions") // Per month
  maxApiCalls    Int @default(10000) @map("max_api_calls")    // Per month
  
  features Json? // { "multiProvider": true, "analytics": "advanced", ... }
  
  isActive   Boolean @default(true) @map("is_active")
  isPublic   Boolean @default(true) @map("is_public")
  isFeatured Boolean @default(false) @map("is_featured")
  isTrial    Boolean @default(false) @map("is_trial")
  sortOrder  Int     @default(0) @map("sort_order")
  
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  
  subscriptions  OrgSubscription[]
  purchases      SubscriptionPurchase[]
  providerAccess SubscriptionProviderAccess[]
  history        SubscriptionHistory[]
  
  @@index([code])
  @@index([isActive])
  @@index([isTrial])
  @@map("subscription_plans")
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  HALF_YEARLY
  YEARLY
  LIFETIME
}

/// Which providers are available in each subscription plan
model SubscriptionProviderAccess {
  id             String @id @default(uuid()) @db.VarChar(36)
  planId         String @map("plan_id") @db.VarChar(36)
  providerCode   String @map("provider_code") @db.VarChar(50)
  
  isIncluded     Boolean @default(true) @map("is_included")
  
  createdAt DateTime @default(now()) @map("created_at")
  
  plan SubscriptionPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  
  @@unique([planId, providerCode])
  @@index([planId])
  @@map("subscription_provider_access")
}

/// Subscription slot — one per purchased plan unit, assignable to a merchant
model OrgSubscription {
  id             String @id @default(uuid()) @db.VarChar(36)
  organizationId String @map("organization_id") @db.VarChar(36)
  planId         String @map("plan_id") @db.VarChar(36)
  merchantId     String? @map("merchant_id") @db.VarChar(36)
  
  status      SlotStatus @default(UNASSIGNED)
  startDate   DateTime   @map("start_date")
  endDate     DateTime?  @map("end_date")
  autoRenew   Boolean    @default(true) @map("auto_renew")
  
  // Custom limits override (if different from plan)
  customLimits Json? @map("custom_limits")
  
  // Groups slots from the same purchase
  purchaseId  String? @map("purchase_id") @db.VarChar(36)
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  plan  SubscriptionPlan @relation(fields: [planId], references: [id])
  
  @@index([planId])
  @@index([status])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([merchantId])
  @@index([purchaseId])
  @@map("org_subscriptions")
}

enum SlotStatus {
  UNASSIGNED
  ACTIVE
  EXPIRED
}

/// Tracks each purchase (1 purchase → N slots, linked to payment order)
model SubscriptionPurchase {
  id             String @id @default(uuid()) @db.VarChar(36)
  organizationId String @map("organization_id") @db.VarChar(36)
  planId         String @map("plan_id") @db.VarChar(36)
  quantity       Int    @default(1)
  totalAmount    Decimal @map("total_amount") @db.Decimal(10, 2)
  
  // Link to payment-service order
  paymentOrderId     String? @map("payment_order_id") @db.VarChar(36)
  paymentExternalId  String? @map("payment_external_id") @db.VarChar(100)
  paymentUtr         String? @map("payment_utr") @db.VarChar(100)
  
  status         PurchaseStatus @default(PENDING)
  
  completedAt    DateTime? @map("completed_at")
  
  createdAt      DateTime @default(now()) @map("created_at")
  metadata       Json?     @map("metadata")
  updatedAt      DateTime @updatedAt @map("updated_at")
  
  plan SubscriptionPlan @relation(fields: [planId], references: [id])
  
  @@index([organizationId])
  @@index([status])
  @@index([paymentOrderId])
  @@index([paymentExternalId])
  @@index([organizationId, status])
  @@map("subscription_purchases")
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  EXPIRED
  FAILED
}

/// Platform-level configuration (subscription payment merchant, etc.)
model PlatformConfig {
  id    String @id @default(uuid()) @db.VarChar(36)
  key   String @unique @db.VarChar(100)
  value Json
  
  updatedAt DateTime @updatedAt @map("updated_at")
  
  @@map("platform_config")
}

/// Audit trail of every plan subscription / switch / renewal
model SubscriptionHistory {
  id             String   @id @default(uuid()) @db.VarChar(36)
  organizationId String   @map("organization_id") @db.VarChar(36)
  planId         String   @map("plan_id") @db.VarChar(36)
  planName       String   @map("plan_name") @db.VarChar(100)
  planPrice      Decimal  @map("plan_price") @db.Decimal(10, 2)
  billingCycle   String   @map("billing_cycle") @db.VarChar(20)
  action         String   @db.VarChar(50) // SUBSCRIBED, UPGRADED, DOWNGRADED, RENEWED, PURCHASED
  previousPlanId String?  @map("previous_plan_id") @db.VarChar(36)
  previousPlanName String? @map("previous_plan_name") @db.VarChar(100)
  gatewayTransactionId String? @map("gateway_transaction_id") @db.VarChar(100)
  quantity       Int      @default(1)
  status         String   @default("SUCCESS") @db.VarChar(20)
  createdAt      DateTime @default(now()) @map("created_at")

  plan SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([organizationId, createdAt])
  @@map("subscription_history")
}

model MerchantUnlock {
  id             String       @id @default(uuid()) @db.VarChar(36)
  organizationId String       @map("organization_id") @db.VarChar(36)
  merchantType   String       @map("merchant_type") @db.VarChar(50) // BHARATPE, GPAY, etc.
  
  unlockType     String       @default("LIFETIME") @map("unlock_type") @db.VarChar(20)
  status         UnlockStatus @default(ACTIVE)
  
  // Link to purchase (null if granted by super-admin)
  purchaseId     String?      @map("purchase_id") @db.VarChar(36)
  
  // Pricing at time of purchase
  pricePaid      Decimal?     @map("price_paid") @db.Decimal(10, 2)
  currency       String?      @default("INR") @db.VarChar(3)
  
  grantedBy      String?      @map("granted_by") @db.VarChar(100) // "PURCHASE" | "SUPER_ADMIN" | "MIGRATION"
  
  unlockedAt     DateTime     @default(now()) @map("unlocked_at")
  revokedAt      DateTime?    @map("revoked_at")
  
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  
  @@unique([organizationId, merchantType])
  @@index([organizationId])
  @@index([merchantType])
  @@index([status])
  @@map("merchant_unlocks")
}

enum UnlockStatus {
  ACTIVE
  REVOKED
}

model MerchantUnlockProduct {
  id            String   @id @default(uuid()) @db.VarChar(36)
  merchantType  String   @unique @map("merchant_type") @db.VarChar(50)
  displayName   String   @map("display_name") @db.VarChar(100)
  description   String?  @db.VarChar(255)
  
  price         Decimal  @db.Decimal(10, 2)
  currency      String   @default("INR") @db.VarChar(3)
  
  isActive      Boolean  @default(true) @map("is_active")
  sortOrder     Int      @default(0) @map("sort_order")
  
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@index([isActive])
  @@map("merchant_unlock_products")
}

model MerchantUnlockPurchase {
  id             String   @id @default(uuid()) @db.VarChar(36)
  organizationId String   @map("organization_id") @db.VarChar(36)
  merchantType   String   @map("merchant_type") @db.VarChar(50)
  totalAmount    Decimal  @map("total_amount") @db.Decimal(10, 2)
  status         String   @default("PENDING") @db.VarChar(20)
  
  paymentOrderId    String? @map("payment_order_id") @db.VarChar(100)
  paymentExternalId String? @map("payment_external_id") @db.VarChar(100)
  paymentUtr        String? @map("payment_utr") @db.VarChar(100)
  
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([organizationId])
  @@index([paymentExternalId])
  @@map("merchant_unlock_purchases")
}

model MonthlyUsage {
  id            String   @id @default(uuid()) @db.VarChar(36)
  orgId         String   @map("org_id") @db.VarChar(36)
  billingMonth  String   @map("billing_month") @db.VarChar(7) // YYYY-MM
  orderCount    Int      @default(0) @map("order_count")
  
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([orgId, billingMonth])
  @@index([orgId])
  @@map("monthly_usage")
}

model UsageAlert {
  id            String   @id @default(uuid()) @db.VarChar(36)
  orgId         String   @map("org_id") @db.VarChar(36)
  billingMonth  String   @map("billing_month") @db.VarChar(7) // YYYY-MM
  milestone     Int      // 70, 80, 90, 100
  emailSentAt   DateTime @default(now()) @map("email_sent_at")

  @@unique([orgId, billingMonth, milestone])
  @@index([orgId])
  @@map("usage_alerts")
}
