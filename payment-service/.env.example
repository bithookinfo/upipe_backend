#
# Payment Service – .env.example
# Copy this file to `.env` and fill in real values.
#

# Service
PORT=3103

# Database
# Example (local MySQL):
#   mysql://user:pass@localhost:3306/greenpay_payment
DATABASE_URL="mysql://user:pass@localhost:3306/greenpay_payment"

# Internal service URLs
MERCHANT_SERVICE_URL="http://localhost:3102"
IDENTITY_SERVICE_URL="http://localhost:3105"
ORGANIZATION_SERVICE_URL="http://localhost:3106"
SUBSCRIPTION_SERVICE_URL="http://localhost:3104"

# Auth
# Must match identity-service JWT_SECRET
JWT_SECRET="change-me-jwt-secret"

# Webhook signing secret for external callbacks
WEBHOOK_SECRET="change-me-webhook-secret"

# Public API / Gateway URLs
# API_GATEWAY_URL – internal URL the payment service uses for callbacks (if needed)
API_GATEWAY_URL="http://localhost:3100/api/v1"

# PUBLIC_API_URL – base URL that merchants use for public payment APIs
PUBLIC_API_URL="http://localhost:3103/api/v1"

# CORS – comma-separated list of allowed origins (frontends)
ALLOWED_ORIGINS=https://upipe.tech,https://app.upipe.tech,https://admin.upipe.tech,http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4000


FRONTEND_URL=https://app.upipe.tech
