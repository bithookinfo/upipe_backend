#
# Identity Service – .env.example
# Copy this file to `.env` and fill in real values.
#

# Service
PORT=3105
NODE_ENV=development

# Database
# Example: mysql://user:pass@localhost:3306/greenpay_identity
DATABASE_URL="mysql://user:pass@localhost:3306/greenpay_identity"

# JWT
# Use long, random strings in production
JWT_SECRET="change-me-jwt-secret"
# Legacy key used in some parts of the codebase
JwtSecret="change-me-jwt-secret"
JWT_REFRESH_SECRET="change-me-refresh-secret"
JWT_EXPIRY="24h"
JWT_REFRESH_EXPIRY="7d"

# MFA
# Name shown in authenticator apps (Google Authenticator, etc.)
MFA_ISSUER="Upipe"

# Bcrypt
BCRYPT_ROUNDS="12"

# Email (for OTP / security emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="noreply@yourdomain.com"

# Notification service (verify email, reset password emails)
NOTIFICATION_SERVICE_URL="http://localhost:3006"
FRONTEND_URL=https://app.upipe.tech
# Set to \"true\" to send verification email after signup (when user has email)
EMAIL_VERIFICATION_ENABLED="true"

# SMS (for OTP)
SMS_PROVIDER="twilio"  # twilio, msg91, etc.
SMS_API_KEY="your-sms-api-key"
SMS_SENDER_ID="UPIPE"

# Downstream services (used for cross-service calls)
ORGANIZATION_SERVICE_URL="http://localhost:3106"
SUBSCRIPTION_SERVICE_URL="http://localhost:3104"
MERCHANT_SERVICE_URL="http://localhost:3102"
PAYMENT_SERVICE_URL="http://localhost:3103"

# CORS – comma-separated list of allowed origins (frontends)
ALLOWED_ORIGINS=https://upipe.tech,https://app.upipe.tech,https://admin.upipe.tech,http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4000
