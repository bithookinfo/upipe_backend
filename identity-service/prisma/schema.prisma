// Identity Service Database Schema
// This service handles authentication, users, sessions, and permissions
// Organization data accessed via API calls

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid()) @db.VarChar(36)
  name          String    @db.VarChar(255)
  email         String?   @unique @db.VarChar(255)
  mobile        String    @unique @db.VarChar(15)
  password      String?   @db.VarChar(255) // Hashed
  
  emailVerified Boolean   @default(false) @map("email_verified")
  mobileVerified Boolean  @default(false) @map("mobile_verified")
  whatsapp      String?   @db.VarChar(15) // Added WhatsApp
  alternateEmail String?  @map("alternate_email") @db.VarChar(255) // Added Alternate Email
  alternateEmailVerified Boolean @default(false) @map("alternate_email_verified") // Added Alternate Email Verification Status
  callbackUrl   String?   @map("callback_url") @db.VarChar(500) // Default webhook URL for orders
  language      String?   @db.VarChar(5) @default("en")
  
  isActive      Boolean   @default(true) @map("is_active")
  lastLoginAt   DateTime? @map("last_login_at")
  
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  
  // Relations
  sessions                    Session[]
  otpLogs                     OtpLog[]
  emailVerificationTokens     EmailVerificationToken[]
  passwordResetTokens         PasswordResetToken[]
  notificationPreferences     UserNotificationPreferences?

  @@index([email])
  @@index([mobile])
  @@index([isActive])
  @@map("users")
}

model SuperAdmin {
  id          String  @id @default(uuid()) @db.VarChar(36)
  name        String  @db.VarChar(255)
  email       String  @unique @db.VarChar(255)
  password    String  @db.VarChar(255) // Hashed
  
  role        String  @default("super_admin") @db.VarChar(50)
  permissions Json?   // JSON array of permission codes
  
  mfaEnabled  Boolean @default(false) @map("mfa_enabled")
  mfaSecret   String? @map("mfa_secret") @db.VarChar(255)
  
  isActive    Boolean   @default(true) @map("is_active")
  organizationId String? @map("organization_id") @db.VarChar(36)
  lastLoginAt DateTime? @map("last_login_at")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  sessions    Session[]
  auditLogs   AuditLog[]
  
  @@index([email])
  @@index([isActive])
  @@map("super_admins")
}

/// Admin Roles for Super Admin Panel (NOT related to org-service's org_roles)
/// These define role templates with permission presets for super admin users
model AdminRole {
  id          String   @id @default(uuid()) @db.VarChar(36)
  name        String   @unique @db.VarChar(100) // e.g. "Finance Auditor"
  key         String   @unique @db.VarChar(50)  // e.g. "finance_auditor" (slug)
  description String?  @db.Text
  permissions Json     // Array of permission codes: ["merchant:view", "payment:view"]
  isSystem    Boolean  @default(false) @map("is_system") // true for built-in roles (can't delete)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([key])
  @@index([isActive])
  @@map("admin_roles")
}

model Session {
  id             String    @id @default(uuid()) @db.VarChar(36)
  userId         String?   @map("user_id") @db.VarChar(36)
  superAdminId   String?   @map("super_admin_id") @db.VarChar(36)
  token          String    @db.Text
  refreshToken   String?   @map("refresh_token") @db.Text
  
  ipAddress      String?   @map("ip_address") @db.VarChar(45)
  userAgent      String?   @map("user_agent") @db.Text
  
  expiresAt      DateTime  @map("expires_at")
  lastActivityAt DateTime  @default(now()) @map("last_activity_at")
  
  createdAt      DateTime  @default(now()) @map("created_at")
  
  user           User?       @relation(fields: [userId], references: [id], onDelete: Cascade)
  superAdmin     SuperAdmin? @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([superAdminId])
  @@index([expiresAt])
  @@map("sessions")
}

model OtpLog {
  id          String    @id @default(uuid()) @db.VarChar(36)
  mobile      String    @db.VarChar(15)
  otpHash     String    @map("otp_hash") @db.VarChar(64)
  reference   String    @unique @db.VarChar(32)
  type        String    @default("sms") @db.VarChar(20)
  userId      String?   @map("user_id") @db.VarChar(36)
  
  expiresAt   DateTime  @map("expires_at")
  verifiedAt  DateTime? @map("verified_at")
  attempts    Int       @default(0)
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([mobile])
  @@index([reference])
  @@index([expiresAt])
  @@map("otp_logs")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  email     String?   @db.VarChar(255) // The email address this token is verifying
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.VarChar(36)
  userId    String    @map("user_id") @db.VarChar(36)
  tokenHash String    @map("token_hash") @db.VarChar(64)
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model UserNotificationPreferences {
  id              String   @id @default(uuid()) @db.VarChar(36)
  userId          String   @unique @map("user_id") @db.VarChar(36)
  accountActivity Boolean  @default(true) @map("account_activity")
  securityAlerts  Boolean  @default(true) @map("security_alerts")
  marketing       Boolean  @default(false) @map("marketing")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notification_preferences")
}

model Permission {
  id          String   @id @default(uuid()) @db.VarChar(36)
  code        String   @unique @db.VarChar(100)
  name        String   @db.VarChar(255)
  description String?  @db.Text
  category    String   @db.VarChar(100)
  service     String?  @db.VarChar(50) // Which service this permission belongs to
  
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  
  userPermissions UserPermission[]
  
  @@index([code])
  @@index([category])
  @@index([service])
  @@map("permissions")
}

model UserPermission {
  id             String   @id @default(uuid()) @db.VarChar(36)
  userId         String   @map("user_id") @db.VarChar(36)
  organizationId String   @map("organization_id") @db.VarChar(36)
  permissionId   String   @map("permission_id") @db.VarChar(36)
  
  // How permission was granted
  grantedBy      String?  @map("granted_by") @db.VarChar(36) // User ID who granted
  grantedVia     String   @default("role") @map("granted_via") @db.VarChar(50) // 'role' or 'direct'
  roleId         String?  @map("role_id") @db.VarChar(36) // If granted via role
  
  grantedAt      DateTime @default(now()) @map("granted_at")
  expiresAt      DateTime? @map("expires_at")
  
  permission     Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@unique([userId, organizationId, permissionId])
  @@index([userId])
  @@index([organizationId])
  @@index([permissionId])
  @@index([userId, organizationId])
  @@map("user_permissions")
}

/// Audit Logs for Super Admin Actions
model AuditLog {
  id           String    @id @default(uuid()) @db.VarChar(36)
  superAdminId String    @map("super_admin_id") @db.VarChar(36)
  
  action       String    @db.VarChar(100)      // ORGANIZATION_ACTIVATED, MERCHANT_SUSPENDED, etc.
  entityType   String    @map("entity_type") @db.VarChar(50)  // organization, merchant, user, etc.
  entityId     String    @map("entity_id") @db.VarChar(36)
  
  details      Json?      // Additional context
  
  ipAddress    String?   @map("ip_address") @db.VarChar(45)
  userAgent    String?   @map("user_agent") @db.Text
  
  createdAt    DateTime  @default(now()) @map("created_at")
  
  superAdmin   SuperAdmin @relation(fields: [superAdminId], references: [id], onDelete: Cascade)
  
  @@index([superAdminId])
  @@index([action])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum AuditAction {
  create
  update
  delete
}

model Translation {
  id           String    @id @default(uuid()) @db.VarChar(36)
  languageCode String    @map("language_code") @db.VarChar(5)
  namespace    String    @default("translation") @db.VarChar(50)
  key          String    @db.VarChar(500)
  value        String    @db.Text
  description  String?   @db.Text
  
  isActive     Boolean   @default(true) @map("is_active")
  isDeleted    Boolean   @default(false) @map("is_deleted")
  
  createdBy    String?   @map("created_by") @db.VarChar(36)
  updatedBy    String?   @map("updated_by") @db.VarChar(36)
  
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  
  audits       TranslationAudit[]
  
  @@unique([languageCode, namespace, key])
  @@index([languageCode])
  @@index([key])
  @@map("translations")
}

model TranslationVersion {
  id           String   @id @default(uuid()) @db.VarChar(36)
  languageCode String   @unique @map("language_code") @db.VarChar(5)
  version      Int      @default(1)
  updatedAt    DateTime @updatedAt @map("updated_at")
  
  @@map("translation_versions")
}

model TranslationAudit {
  id             String      @id @default(uuid()) @db.VarChar(36)
  translationId  String      @map("translation_id") @db.VarChar(36)
  languageCode   String      @map("language_code") @db.VarChar(5)
  key            String      @db.VarChar(500)
  oldValue       String?     @map("old_value") @db.Text
  newValue       String      @map("new_value") @db.Text
  changedBy      String?     @map("changed_by") @db.VarChar(36)
  action         AuditAction
  changedAt      DateTime    @default(now()) @map("changed_at")
  
  translation    Translation @relation(fields: [translationId], references: [id], onDelete: Cascade)
  
  @@index([translationId])
  @@index([languageCode])
  @@map("translation_audits")
}
