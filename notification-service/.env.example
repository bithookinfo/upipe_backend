# Copy to .env and set real values. Never commit .env.
# SMTP (e.g. aaPanel, SendGrid, Gmail, or your mail server)
SMTP_HOST=your-smtp-host.example.com
SMTP_PORT=587
SMTP_USER=noreply@your-domain.com
SMTP_PASS=your-password

# Optional: separate mailbox for alert/order emails
SMTP_USER_ALERTS=alerts@your-domain.com
SMTP_PASS_ALERTS=your-alerts-password

# From addresses (auth = verify/reset; alerts = order completion / system)
FROM_EMAIL_AUTH=noreply@your-domain.com
FROM_EMAIL_ALERTS=alerts@your-domain.com
FROM_EMAIL=noreply@your-domain.com
REPLY_TO_EMAIL=alerts@your-domain.com

# App (used in email templates)
APP_NAME=YourApp
FRONTEND_URL=https://app.upipe.tech

PORT=3006

# VAPID keys for PWA push (generate: npx web-push generate-vapid-keys)
# Public key also goes in client-admin as VITE_VAPID_PUBLIC_KEY; keep private key only here
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

ALLOWED_ORIGINS=https://upipe.tech,https://app.upipe.tech,https://admin.upipe.tech,http://localhost:5173,http://localhost:5174,http://localhost:3000,http://localhost:4000
