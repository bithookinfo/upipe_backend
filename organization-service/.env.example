#
# Organization Service – .env.example
# Copy this file to `.env` and fill in real values.
#

# Service
PORT=3106

# Database
# Example (local MySQL):
#   mysql://user:pass@localhost:3306/greenpay_organization?connection_limit=5
DATABASE_URL="mysql://user:pass@localhost:3306/greenpay_organization?connection_limit=5"

# Identity service URL (for auth / users)
IDENTITY_SERVICE_URL="http://localhost:3105"

# JWT – must match identity-service JWT_SECRET
JWT_SECRET="change-me-jwt-secret"

# CORS – comma-separated list of allowed origins (frontends)
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:5174"

